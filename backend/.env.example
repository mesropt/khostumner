# Khostumner backend — environment variable template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://khostumner:khostumner@localhost:5432/khostumner

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
DB_ECHO=false
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Auth — JWT and CSRF secrets
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-random-32-char-string
CSRF_SECRET=change-me-to-another-random-32-char-string

# ---------------------------------------------------------------------------
# Email (SMTP)
# Dev default: Mailhog on Docker (no auth, port 1025, web UI at :8025)
# ---------------------------------------------------------------------------
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@khostumner.am

# ---------------------------------------------------------------------------
# OAuth - Google
# Setup: https://console.cloud.google.com/ > Credentials > OAuth 2.0 Client ID
# Callback URL to register: http://localhost:8000/api/auth/google/callback
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------------------------------------------------------------------------
# OAuth - Facebook
# Setup: https://developers.facebook.com/ > My Apps > Facebook Login
# Callback URL to register: http://localhost:8000/api/auth/facebook/callback
# ---------------------------------------------------------------------------
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
